<view class="page">
  <view class="section-title">01 基本信息</view>
  <t-input label="出发地" placeholder="请输入出发地" />
  <t-input label="目的地" placeholder="请输入目的地" />
  <t-input label="出发日期" placeholder="请选择开始日期 - 结束日期" />
  <view class="inline">
    <t-input label="游玩天数" type="number" placeholder="天数" />
    <t-input label="人均预算" type="number" placeholder="预算（元）" />
  </view>

  <view class="counter-row">
    <text>成人</text>
    <t-stepper value="{{adult}}" data-key="adult" bindchange="onStepChange" />
  </view>
  <view class="counter-row">
    <text>儿童</text>
    <t-stepper value="{{child}}" data-key="child" bindchange="onStepChange" />
  </view>

  <view class="section-title">02 特色定制</view>
  <t-radio-group value="{{hotel}}">
    <t-radio value="三星/舒适">三星/舒适</t-radio>
    <t-radio value="四星/高档">四星/高档</t-radio>
    <t-radio value="五星/豪华">五星/豪华</t-radio>
    <t-radio value="连锁酒店">连锁酒店</t-radio>
    <t-radio value="特色客栈">特色客栈</t-radio>
    <t-radio value="不限">不限</t-radio>
  </t-radio-group>

  <view class="section-title">用餐要求</view>
  <t-radio-group value="{{meal}}">
    <t-radio value="当地特色">当地特色</t-radio>
    <t-radio value="定制师推荐">定制师推荐</t-radio>
    <t-radio value="自理">自理</t-radio>
  </t-radio-group>

  <t-textarea label="其他需求" placeholder="请填写景点偏好、住宿偏好、出行方式等" />

  <view class="section-title">03 联系人信息</view>
  <t-input label="姓名" required placeholder="请输入姓名" />
  <t-input label="手机号" required placeholder="请输入手机号" />

  <t-button block theme="primary" bindtap="submit">提交定制</t-button>
</view>

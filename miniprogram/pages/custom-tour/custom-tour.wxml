<scroll-view class="page" scroll-y>
  <view class="block">
    <view class="section-title">01 基本信息</view>
    <t-input label="出发地" placeholder="请输入" />
    <t-input label="目的地" placeholder="请输入" />
    <t-input label="出发日期" placeholder="请选择开始日期" />
    <t-input label="结束日期" placeholder="请选择结束日期" />
    <t-input label="游玩天数" placeholder="请输入" />
    <t-input label="人均预算" placeholder="请输入预算" />
    <view class="row"><text>成人</text><t-stepper value="2" /></view>
    <view class="row"><text>儿童</text><t-stepper value="0" /></view>
  </view>
  <view class="block">
    <view class="section-title">02 特色定制</view>
    <view class="label">酒店星级</view>
    <t-radio-group value="4星">
      <t-radio name="3星" label="三星/舒适" />
      <t-radio name="4星" label="四星/高档" />
      <t-radio name="5星" label="五星/豪华" />
    </t-radio-group>
    <view class="label">其他需求</view>
    <t-textarea placeholder="请输入定制要求" />
  </view>
  <view class="block">
    <view class="section-title">03 联系人信息</view>
    <t-input label="姓名" required placeholder="请输入姓名" />
    <t-input label="手机号" required placeholder="请输入手机号" />
  </view>
  <t-button theme="primary" block size="large">提交定制</t-button>
  <view class="bottom-gap"></view>
</scroll-view>

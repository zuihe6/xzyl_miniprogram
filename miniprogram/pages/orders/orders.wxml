<view class="page">
  <t-radio-group default-value="all" placement="horizontal">
    <t-radio value="all">全部订单</t-radio>
    <t-radio value="pay">待付款</t-radio>
    <t-radio value="use">待使用</t-radio>
    <t-radio value="refund">退款售后</t-radio>
  </t-radio-group>

  <view class="list">
    <t-card wx:for="{{orders}}" wx:key="no" title="{{item.title}}" description="订单号：{{item.no}}" note="{{item.status}}">
      <view slot="footer" class="footer">
        <text class="price">¥{{item.amount}}</text>
        <t-button size="small" variant="outline">删除订单</t-button>
      </view>
    </t-card>
  </view>
</view>

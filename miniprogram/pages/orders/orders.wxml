<view class="page">
  <t-radio-group default-value="all" placement="horizontal">
    <t-radio value="all">全部订单</t-radio>
    <t-radio value="pay">待付款</t-radio>
    <t-radio value="use">待使用</t-radio>
    <t-radio value="refund">退款售后</t-radio>
  </t-radio-group>

  <view class="list">
    <view class="order-card" wx:for="{{orders}}" wx:key="no">
      <view class="order-title">{{item.title}}</view>
      <view class="order-no">订单号：{{item.no}}</view>
      <view class="footer">
        <text>{{item.status}} · <text class="price">¥{{item.amount}}</text></text>
        <t-button size="small" variant="outline">删除订单</t-button>
      </view>
    </view>
  </view>
</view>

<view class="page">
  <view class="chat-title">西藏野狼 · AI智能客服</view>
  <t-card title="AI导游助手" description="您好！欢迎来到西藏野狼旅行社🏔️ 我可以帮您查询线路和报价、解答高原旅行问题、预订租车和行程。" />

  <view class="quick-row">
    <t-button size="small" variant="outline" bindtap="onQuickTap" data-text="租车咨询">🚗 租车咨询</t-button>
    <t-button size="small" variant="outline" bindtap="onQuickTap" data-text="参团游">🧳 参团游</t-button>
    <t-button size="small" variant="outline" bindtap="onQuickTap" data-text="定制行程">✨ 定制行程</t-button>
  </view>

  <t-input placeholder="请输入问题，例如：林芝桃花线路价格" align="left" />
  <t-button theme="primary" block>发送</t-button>
</view>

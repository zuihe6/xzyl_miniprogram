.page { padding-bottom: 130rpx; }
.cover { height: 300rpx; border-radius: 16rpx; background: linear-gradient(140deg,#415,#768); }
.title { font-size: 34rpx; font-weight: 700; margin-top: 16rpx; }
.price-row { display: flex; justify-content: space-between; align-items: center; margin: 16rpx 0; }
.price { color: #e34d59; font-weight: 700; }
.highlight { background: #fff7e8; border-radius: 12rpx; padding: 16rpx; color: #a86a00; margin-bottom: 16rpx; }
.bottom { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-top: 1rpx solid #eee; padding: 16rpx 24rpx; display: flex; justify-content: space-between; align-items: center; }

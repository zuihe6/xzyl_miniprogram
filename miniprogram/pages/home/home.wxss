.location-row {
  margin: 16rpx 0;
  display: flex;
  justify-content: space-between;
  color: #666;
}

.brand {
  color: #1a6b3a;
  font-weight: 600;
}

.tag-row {
  white-space: nowrap;
  margin: 20rpx 0;
}

.tag-row t-tag {
  margin-right: 12rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.more {
  color: #1a6b3a;
  font-size: 24rpx;
}
.tour-card{background:#fff;border-radius:16rpx;padding:20rpx;margin-bottom:16rpx;}
.tour-name{font-weight:600;margin-bottom:8rpx;}
.tour-tags{color:#666;margin-bottom:8rpx;}

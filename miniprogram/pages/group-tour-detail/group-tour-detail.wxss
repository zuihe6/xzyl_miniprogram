.page { padding-bottom: 130rpx; }
.top-card,.block { background: #fff; border-radius: 16rpx; padding: 16rpx; margin-bottom: 16rpx; }
.img { height: 260rpx; border-radius: 12rpx; background: linear-gradient(130deg,#345,#89a); margin-bottom: 12rpx; }
.title { font-weight: 700; }
.spot { font-size: 24rpx; color: #777; margin-top: 8rpx; }
.label { margin-bottom: 12rpx; color: #666; }
.date-list { display: flex; gap: 10rpx; flex-wrap: wrap; }
.row { display: flex; justify-content: space-between; align-items: center; }
.bottom { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-top: 1rpx solid #eee; padding: 16rpx 24rpx; display: flex; justify-content: space-between; align-items: center; }
.price { color: #e34d59; font-weight: 700; }

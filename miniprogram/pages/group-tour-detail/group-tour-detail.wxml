<scroll-view class="page" scroll-y>
  <view class="top-card">
    <view class="img"></view>
    <view class="title">雅鲁藏布大峡谷一日游（林芝出发）</view>
    <view class="spot">南迦巴瓦峰 / 两江汇流 / 佛掌沙丘</view>
  </view>

  <view class="block">
    <view class="label">选择日期</view>
    <view class="date-list">
      <t-tag wx:for="{{dates}}" wx:key="text" theme="primary" variant="{{index===0?'dark':'light'}}">{{item.text}} {{item.price}}</t-tag>
    </view>
  </view>

  <view class="block row"><text>选择数量</text><t-stepper value="1" /></view>

  <view class="block">
    <t-input label="联系人姓名" required placeholder="请输入姓名" />
    <t-input label="手机号码" required placeholder="请输入手机号码" />
  </view>

  <t-cell-group title="产品介绍">
    <t-cell title="小团纯玩，含正规营运车辆与司导服务，支持15天内日期选择。" />
  </t-cell-group>
  <view class="bottom-gap"></view>
</scroll-view>
<view class="bottom">
  <text class="price">合计：¥399 起</text>
  <t-button theme="primary">立即购买</t-button>
</view>

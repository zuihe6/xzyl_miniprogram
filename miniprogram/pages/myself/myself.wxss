.profile {
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 28rpx;
  border-radius: 16rpx;
  color: #fff;
  background: linear-gradient(135deg, #0d3a25, #1a6b3a 60%, #2d9b5a);
  margin-bottom: 20rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
}

.phone {
  margin-top: 8rpx;
  opacity: 0.85;
}

.item { display: flex; gap: 16rpx; background: #fff; margin-top: 16rpx; border-radius: 12rpx; padding: 16rpx; }
.thumb { width: 180rpx; height: 140rpx; border-radius: 12rpx; background: linear-gradient(120deg,#566,#899); }
.info { flex: 1; }
.title { font-weight: 600; margin-bottom: 8rpx; }
.desc { color: #888; font-size: 24rpx; margin-bottom: 8rpx; }
.actions { display: flex; justify-content: space-between; align-items: center; margin-top: 10rpx; }
.price { color: #e34d59; font-weight: 600; }

<view class="page">
  <view class="car-info">
    <view class="thumb"></view>
    <view>
      <view class="name">丰田普拉多 2.7L</view>
      <view class="count">购买数量：1</view>
    </view>
  </view>
  <t-input label="姓名" required placeholder="请输入姓名" />
  <t-input label="手机号" required placeholder="请输入手机号" />
  <t-input label="用车城市" required placeholder="请选择用车城市" />
  <t-input label="接驳地址" required placeholder="请输入接驳地址" />
  <t-input label="用车时间" required placeholder="请选择时间" />
  <view class="row"><text>用车天数</text><t-stepper value="1" theme="filled" /></view>
  <view class="row"><text>用车人数</text><t-stepper value="2" theme="filled" /></view>
  <t-textarea label="其他需求" placeholder="选填" />
</view>
<view class="bottom">
  <text class="price">合计：¥980 元</text>
  <t-button theme="primary">提交订单</t-button>
</view>

.page { padding-bottom: 130rpx; }
.car-info { background: #fff; border-radius: 12rpx; padding: 16rpx; display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.thumb { width: 160rpx; height: 120rpx; border-radius: 12rpx; background: linear-gradient(140deg,#456,#89a); }
.name { font-weight: 700; }
.count { margin-top: 10rpx; color: #888; }
.row { margin-top: 16rpx; background: #fff; border-radius: 12rpx; padding: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.bottom { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-top: 1rpx solid #eee; padding: 16rpx 24rpx; display: flex; justify-content: space-between; align-items: center; }
.price { color: #e34d59; font-weight: 700; }

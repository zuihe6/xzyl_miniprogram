<view class="page">
  <view class="hero">
    <view class="tag">一站式服务 · 纯玩小团</view>
    <view class="hero-title">开启属于你的西藏之旅</view>
    <view class="sub">Enjoy your Tibet trip with Wild Wolf Travel</view>
    <view class="desc">享受安心出游，去邂逅桃花与美好</view>
  </view>

  <t-card wx:for="{{tours}}" wx:key="title" title="{{item.title}}" description="{{item.tip}}" note="¥{{item.price}} 起/人" bindtap="goDetail">
    <view slot="content" class="spot">{{item.spot}}</view>
    <view slot="footer" class="footer">
      <t-button size="small" theme="primary" bindtap="goDetail">点击购买</t-button>
    </view>
  </t-card>
</view>

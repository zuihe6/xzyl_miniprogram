.hero { padding: 40rpx 24rpx; border-radius: 20rpx; color: #fff; background: linear-gradient(130deg,#0d4a2e,#36895d); margin-bottom: 20rpx; }
.hero-sub { opacity: .9; font-size: 24rpx; }
.hero-title { font-size: 44rpx; font-weight: 700; margin-top: 8rpx; }
.item { background: #fff; border-radius: 16rpx; margin-bottom: 16rpx; padding: 16rpx; display: flex; gap: 14rpx; }
.img { width: 160rpx; border-radius: 12rpx; background: linear-gradient(120deg,#567,#9ab); }
.info { flex: 1; }
.title { font-size: 26rpx; font-weight: 600; }
.sub,.spot { font-size: 22rpx; color: #777; margin-top: 8rpx; }
.bottom-row { margin-top: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.price { color: #e34d59; font-weight: 700; }

.hero {
  border-radius: 16rpx;
  padding: 28rpx;
  color: #fff;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #0d3a25, #1a6b3a 60%, #2d9b5a);
}

.tag {
  font-size: 22rpx;
  opacity: 0.85;
}

.hero-title {
  margin: 12rpx 0;
  font-size: 42rpx;
  font-weight: 700;
}

.sub {
  font-size: 22rpx;
  opacity: 0.8;
}

.desc {
  margin-top: 20rpx;
}
.tour-card{background:#fff;border-radius:16rpx;padding:20rpx;margin-bottom:16rpx;}
.tour-title{font-weight:600;margin-bottom:8rpx;}
.tour-tip,.spot{color:#666;margin-bottom:8rpx;}
.footer {
  display: flex;
  justify-content: space-between;align-items:center;
}

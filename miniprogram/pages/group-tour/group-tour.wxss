.hero {
  border-radius: 16rpx;
  padding: 28rpx;
  color: #fff;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #0d3a25, #1a6b3a 60%, #2d9b5a);
}

.tag {
  font-size: 22rpx;
  opacity: 0.85;
}

.hero-title {
  margin: 12rpx 0;
  font-size: 42rpx;
  font-weight: 700;
}

.sub {
  font-size: 22rpx;
  opacity: 0.8;
}

.desc {
  margin-top: 20rpx;
}

.spot {
  color: #666;
  margin: 12rpx 0;
}

.footer {
  display: flex;
  justify-content: flex-end;
}

t-card {
  margin-bottom: 16rpx;
}
